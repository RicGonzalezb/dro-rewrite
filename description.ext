// ============================================================
// M3 — CfgFunctions migration (replaces #include lib pattern)
// All functions available as DRO_fnc_<name> before mission init
// ============================================================
class CfgFunctions
{
    class DRO
    {
        // -------------------------------------------------
        // Core lib functions (migrated from sundayFunctions,
        // droFunctions, menuFunctions, reviveFunctions,
        // generateEnemiesFunctions). Files in functions/fn_*.sqf
        // -------------------------------------------------
        class core
        {
            file = "functions";
            class AIHeal {};
            class AIListen {};
            class addArsenal {};
            class addConstructAction {};
            class addConstructPoint {};
            class addIntel {};
            class addResetAction {};
            class addReviveToUnit {};
            class addSabotageAction {};
            class assignTask {};
            class avgPos {};
            class backpackFix {};
            class briefingJIP {};
            class callLoadScreen {};
            class changeLocal {};
            class checkAOIndexes {};
            class checkAllDeadFleeing {};
            class checkIntersect {};
            class checkRouteWater {};
            class checkVehicleSpawn {};
