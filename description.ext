/* =====================================================================
   FACTION PARAMS GENERATOR  (optional tool, run it whenever you want)
   ---------------------------------------------------------------------
   Detects ALL installed factions (vanilla + mods) and produces the two
   ready-to-paste blocks — making modded factions available in the LOBBY
   PARAMETERS tab (the in-game UI/sundayDialog already detects them on its
   own; this is only for the Parameters tab, which is static config).

   HOW TO USE:
   1. Start any mission with the faction mods loaded.
   2. Open the Debug Console (Editor: ESC > Debug Console; MP: as admin).
   3. Paste the WHOLE SQF code between the <CODE> markers below and Execute.
   4. The output goes to the clipboard (Ctrl+V) and to the .rpt.
   5. BLOCK A -> replace, here in description.ext, the 9 faction classes
      (from class DRO_ParamPlayerFaction to class DRO_ParamEnemyAdv3).
   6. BLOCK B -> replace, in loadParams.sqf, the 3 map lines
      (_combatFactionMap / _advFactionMap / _civFactionMap).
   7. Save and reload the mission. New factions show in Lobby > Parameters.

   NOTE: params are INDEX-based (alphabetical by classname). If you
   REGENERATE after adding mods, the indices shift — re-check the values
   in server.cfg after regenerating.
   ---------------------------------------------------------------------
   <CODE>

   _dq = toString [34];
   _nl = toString [10];

   _sideOf = {
       params ["_facCfg"];
       if (isNumber (_facCfg >> "side")) exitWith { getNumber (_facCfg >> "side") };
       private _t = toLower getText (_facCfg >> "side");
       if ((_t find "west") >= 0) exitWith {1};
       if ((_t find "east") >= 0) exitWith {0};
       if (((_t find "guer") >= 0) || ((_t find "ind") >= 0)) exitWith {2};
       if ((_t find "civ") >= 0) exitWith {3};
       -1
   };

   _factions = [];
   _seen = [];
   {
       private _cn = configName _x;
       if (getNumber (_x >> "scope") == 2 && {_cn isKindOf "Man"}) then {
           private _fac = getText (_x >> "faction");
           if (_fac != "" && {!(_fac in _seen)}) then {
               _seen pushBack _fac;
               private _facCfg = configFile >> "CfgFactionClasses" >> _fac;
               if (isClass _facCfg) then {
                   private _name = getText (_facCfg >> "displayName");
                   if (_name isEqualTo "") then { _name = _fac };
                   private _sn = [_facCfg] call _sideOf;
                   if (_sn in [0,1,2,3]) then { _factions pushBack [_fac, _name, _sn] };
               };
           };
       };
   } forEach ("(configName _x) isKindOf 'AllVehicles'" configClasses (configFile >> "CfgVehicles"));

   _factions = [_factions, [], { _x select 0 }, "ASCEND"] call BIS_fnc_sortBy;
   _combat = _factions select { (_x select 2) != 3 };
   _civ    = _factions select { (_x select 2) == 3 };

   _quote = { private _arr = _this; (_arr apply { _dq + _x + _dq }) joinString "," };
   _seq   = { private _n = _this; private _r = []; for "_i" from 0 to (_n - 1) do { _r pushBack str _i }; _r joinString "," };

   _mainNames = ["Random"]  + (_combat apply { (_x select 1) + " (" + (_x select 0) + ")" });
   _advNames  = ["None"]    + (_combat apply { _x select 1 });
   _civNames  = ["Default"] + (_civ    apply { (_x select 1) + " (" + (_x select 0) + ")" });
   _combatMap = ["RANDOM"]  + (_combat apply { _x select 0 });
   _advMap    = [""]        + (_combat apply { _x select 0 });
   _civMap    = [""]        + (_civ    apply { _x select 0 });

   _specs = [
       ["DRO_ParamPlayerFaction","Player Faction",_mainNames],
       ["DRO_ParamEnemyFaction","Enemy Faction",_mainNames],
       ["DRO_ParamCivFaction","Civilian Faction",_civNames],
       ["DRO_ParamPlayerAdv1","Player Adv Faction 1",_advNames],
       ["DRO_ParamPlayerAdv2","Player Adv Faction 2",_advNames],
       ["DRO_ParamPlayerAdv3","Player Adv Faction 3",_advNames],
       ["DRO_ParamEnemyAdv1","Enemy Adv Faction 1",_advNames],
       ["DRO_ParamEnemyAdv2","Enemy Adv Faction 2",_advNames],
       ["DRO_ParamEnemyAdv3","Enemy Adv Faction 3",_advNames]
   ];

   _lines = [""];
   {
      _x params ["_cls","_title","_names"];
       _lines pushBack ("	class " + _cls + " {");
       _lines pushBack ("		title = " + _dq + _title + _dq + ";");
       _lines pushBack ("		values[] = {" + ((count _names) call _seq) + "};");
       _lines pushBack ("		texts[] = {" + (_names call _quote) + "};");
       _lines pushBack "		default = 0;";
       _lines pushBack "	};";
   } forEach _specs;

   _lines pushBack "";
   _lines pushBack "// ===== BLOCK B -> loadParams.sqf (replaces the 3 maps) =====";
   _lines pushBack ("private _combatFactionMap = [" + (_combatMap call _quote) + "];");
   _lines pushBack ("private _advFactionMap = [" + (_advMap call _quote) + "];");
   _lines pushBack ("private _civFactionMap = [" + (_civMap call _quote) + "];");

   _out = _lines joinString _nl;
   copyToClipboard _out;
   diag_log _out;
   hint format ["DRO: %1 combat factions + %2 civilian factions generated. Output on clipboard (Ctrl+V) and in the .rpt.", (count _combatMap) - 1, (count _civMap) - 1];

   </CODE>
   ===================================================================== */

/* =====================================================================
   REFERENCIA — server.cfg  (este bloco NAO eh lido pelo description.ext)
   ---------------------------------------------------------------------
   class Missions vai no server.cfg do servidor DEDICADO, nao aqui.
   Copie o conteudo abaixo para o seu server.cfg e ajuste o "template".
   Os valores sao os indices dos params definidos em class Params acima.
   Exemplo: override ON + faccoes via params (pula a UI e gera direto).

   class Missions
   {
       class DRO_Livonia
       {
           template   = "Dynamic Recon Ops ACE - Livonia.Enoch"; // pasta/.pbo em mpmissions, sem .pbo
           difficulty = "Custom";
           class Params
           {
               // ---- MASTER ----
               DRO_ParamOverride      = 1;  // 0=usa UI in-game | 1=usa params do lobby
               // ---- FACTIONS ----
               DRO_ParamUseFactions   = 1;  // 0=escolhe na UI | 1=usa params e PULA a UI
               // Faccoes: indices 0-71 (0=Random). Tabela COMPLETA e autoritativa em class Params acima
               // (DRO_ParamPlayerFaction). Os indices DEPENDEM dos mods instalados — regenere com o gerador
               // de faccoes (bloco comentado mais acima) se mudar os mods, senao os indices deslocam.
               DRO_ParamPlayerFaction = 2;  // ex: 2=NATO (BLU_F)
               DRO_ParamEnemyFaction  = 8;  // ex: 8=LDF (IND_E_F)   [ATENCAO: a tabela mudou; antes 7=LDF, hoje 7=Syndikat]
               DRO_ParamCivFaction    = 0;  // 0=Default | 1..6 (ver class Params: CIV_F, IDAP, LOP_AFR/CHR/TAK, Virtual)
               DRO_ParamPlayerAdv1    = 0;  DRO_ParamPlayerAdv2 = 0;  DRO_ParamPlayerAdv3 = 0; // faccoes advanced: 0=None (ver class Params p/ indices)
               DRO_ParamEnemyAdv1     = 0;  DRO_ParamEnemyAdv2  = 0;  DRO_ParamEnemyAdv3  = 0;
               // ---- SCENARIO ----
               DRO_ParamPreset        = 1;  // 1=Recon 2=Sniper 3=Combined
               DRO_ParamExtendedAO    = 0;  // 0=Enabled 1=Disabled
               DRO_ParamAISkill       = 2;  // 0=Normal 1=Hard 2=Custom
               DRO_ParamEnemySize     = 10; // 5,8,10,12,15,17  (=x0.5 .. x1.7)
               DRO_ParamMines         = 0;  // 0=Disabled 1=Enabled
               DRO_ParamCivilians     = 0;  // 0=Random 1=Enabled 2=Enabled&Hostile 3=Disabled
               DRO_ParamCivAgents     = 0;  // 0=Enabled 1=Disabled
               DRO_ParamArsenal       = 0;  // 0=Enabled 1=Disabled
               DRO_ParamStealth       = 0;  // 0=Random 1=Enabled 2=Disabled
               DRO_ParamRevive        = 3;  // 0=300s 1=120s 2=60s 3=Disabled
               DRO_ParamStamina       = 0;  // 0=Enabled 1=Disabled
               DRO_ParamDynSim        = 0;  // 0=Enabled 1=Disabled
               // ---- ENVIRONMENT ----
               DRO_ParamTimeOfDay     = 0;  // 0=Random 1=Dawn 2=Morning 3=Midday 4=Afternoon 5=Dusk 6=Evening 7=Midnight
               DRO_ParamWeather       = 0;  // 0=Random 1=Clear 2=Light 3=Overcast 4=Storm
               DRO_ParamMonth         = 0;  // 0=Random | 1-12
               DRO_ParamDay           = 0;  // 0=Random | 1-31
               DRO_ParamAnimals       = 0;  // 0=Enabled 1=Disabled
               // ---- OBJECTIVES ----
               DRO_ParamNumObjectives = 0;  // 0=Random | 1-5
               DRO_ParamObjHVT        = 0;  // cada tipo: 0=Disabled 1=Enabled
               DRO_ParamObjPOW        = 1;
               DRO_ParamObjIntel      = 1;
               DRO_ParamObjCache      = 0;
               DRO_ParamObjAsset      = 0;
               DRO_ParamObjSteal      = 0;
               DRO_ParamObjClear      = 0;
               DRO_ParamObjFortify    = 0;
               DRO_ParamObjDisarm     = 0;
               DRO_ParamObjProtect    = 0;
               // ---- INSERTION & SUPPORTS (usados quando DRO_ParamOverride==1; uma lobby pulada usa estes) ----
               DRO_ParamSkipTeamPlanning = 0;  // 0=mostra a lobby de Team Planning | 1=pula (aplica os params abaixo direto)
               DRO_ParamInsertType    = 0;  // 0=Random 1=Ground 2=Air-HALO 3=Air-Helicopter 4=None
               DRO_ParamSupplyDrop    = 0;  // 0=Disabled 1=Enabled
               DRO_ParamArtillery     = 0;  // 0=Disabled 1=Enabled
               DRO_ParamCAS           = 0;  // 0=Disabled 1=Enabled
               DRO_ParamUAV           = 0;  // 0=Disabled 1=Enabled
               // ---- GAMEPLAY (params originais) ----
               Respawn                = 0;  // 0=20s 1=45s 2=90s 3=5min 4=10min 5=20min 6=30min 7=Disabled
               RespawnPositions       = 0;  // 0=Both 1=Start only 2=Team only
               Stamina                = 0;  // 0=Enabled 1=Disabled
               AIWeaponLight          = 1;  // 0=Auto 1=Force On 2=Force Off
           };
       };
   };
   ===================================================================== */

class RscTitles {
	class DRO_Splash {
		idd = -1;
		duration = 60;
		movingenable = 0;
		class Controls {
			class facade1: sundayText
			{
				idc = 1000;
				text = "";
				x = 0 * safezoneW + safezoneX;
				y = 0 * safezoneH + safezoneY;
				w = 0.15 * safezoneW;
				h = 1 * safezoneH;
				colorBackground[] = { 0, 0, 0, 1 };
				fade = 0;
			};
			class facade2: sundayText
			{
				idc = 1001;
				text = "";
				x = 0.85 * safezoneW + safezoneX;
				y = 0 * safezoneH + safezoneY;
				w = 0.15 * safezoneW;
				h = 1 * safezoneH;
				colorBackground[] = { 0, 0, 0, 1 };	
				fade = 0;
			};	
			class splash: RscPicture
			{			
				idc = 1002;
				text = "images\DRO_splash_square.paa";
				x = 0.15 * safezoneW + safezoneX;
				y = 0.0 * safezoneH + safezoneY;
				w = 0.7 * safezoneW;
				h = 1 * safezoneH;
				fade = 0;
			};		
		};		
	};
};

class CfgCommunicationMenu
{   
	class heliExtract
    {
        text = "Request extraction"; // Text displayed in the menu and in a notification
        submenu = ""; // Submenu opened upon activation (expression is ignored when submenu is not empty.)
        expression = "[_pos] execVM 'sunday_system\heliExtract.sqf'"; // Code executed upon activation
        icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\transport_ca.paa"; // Icon displayed permanently next to the command menu
        cursor = "\a3\Ui_f\data\IGUI\Cfg\Cursors\iconCursorSupport_ca.paa"; // Custom cursor displayed when the item is selected
        enable = "1"; // Simple expression condition for enabling the item
        removeAfterExpressionCall = 1; // 1 to remove the item after calling
    };
	class extractLeave
    {
        text = "Extract"; // Text displayed in the menu and in a notification
        submenu = ""; // Submenu opened upon activation (expression is ignored when submenu is not empty.)
        expression = "extractLeave = true; publicVariable 'extractLeave'"; // Code executed upon activation
        icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\transport_ca.paa"; // Icon displayed permanently next to the command menu
        cursor = ""; // Custom cursor displayed when the item is selected
        enable = "1"; // Simple expression condition for enabling the item
        removeAfterExpressionCall = 1; // 1 to remove the item after calling
    };	
	class DRO_Support_Request_Artillery
	{
		cursor = "\A3\ui_f\data\igui\cfg\cursors\iconCursorSupport_ca.paa";
		enable = "cursorOnGround";
		expression = "[_pos] execVM 'sunday_system\supports\supportArtyComms.sqf'";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\artillery_ca.paa";
		text = "Artillery strike";		
	};
	class DRO_Support_Request_CAS_Bombing
	{
		cursor = "\A3\ui_f\data\igui\cfg\cursors\iconCursorSupport_ca.paa";
		enable = "cursorOnGround";
		expression = "[_pos] execVM 'sunday_system\supports\supportCASHeli.sqf'";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\cas_ca.paa";
		text = "CAS (bombing run)";	
	};
	class DRO_Support_Request_CAS_Heli
	{
		cursor = "\A3\ui_f\data\igui\cfg\cursors\iconCursorSupport_ca.paa";
		enable = "cursorOnGround";
		expression = "[_pos] execVM 'sunday_system\supports\supportCASHeli.sqf'";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\casheli_ca.paa";
		text = "CAS (helicopter attack)";
		removeAfterExpressionCall = 1;
	};
	class DRO_Support_Request_Drop
	{
		cursor = "\A3\ui_f\data\igui\cfg\cursors\iconCursorSupport_ca.paa";
		enable = "cursorOnGround";
		expression = "[_pos] execVM 'sunday_system\supports\heliDrop.sqf'";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\supplydrop_ca.paa";
		text = "Supply drop";
		removeAfterExpressionCall = 1;
	};
	class DRO_Support_Request_Transport
	{
		cursor = "\A3\ui_f\data\igui\cfg\cursors\iconCursorSupport_ca.paa";
		enable = "cursorOnGround";
		expression = "player setVariable ['BIS_SUPP_request', ['Transport', _pos]]";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\transport_ca.paa";
		text = "Helicopter transport";
	};
	class DRO_Friendly_Engage
	{
		cursor = "";
		enable = "1";
		expression = "DRO_beginFriendlyAssault = true; publicVariable 'DRO_beginFriendlyAssault'";
		icon = "\a3\Ui_f\data\GUI\Cfg\CommunicationMenu\attack_ca.paa";
		text = "Begin Assault";
		removeAfterExpressionCall = 1;
	};
};

class CfgDebriefing
{  
	class DROEnd_Full
	{
		title = "Mission Completed";
		subtitle = "";
		description = "With all objectives completed the mission was a success and a stepping stone to further control of the region.";
		pictureBackground = "images\recon_image_notext.jpg";
		picture = "";
		pictureColor[] = {0.0,0.3,0.6,1};
	};
	class DROEnd_Partial
	{
		title = "Mission Completed";
		subtitle = "";
		description = "The mission did not go to plan and further operations had to be rethought to accommodate an appropriate response.";
		pictureBackground = "images\recon_image_notext.jpg";
		picture = "";
		pictureColor[] = {0.0,0.3,0.6,1};
	};
	class DROEnd_Fail
	{
		title = "Mission Failed";
		subtitle = "";
		description = "With none of the objectives completed the mission was considered a failure and your team was reassigned. Unchecked, the enemy expanded their influence on the region.";
		pictureBackground = "images\recon_image_notext.jpg";
		picture = "";
		pictureColor[] = {0.5,0.4,0.4,1};
	};
	class DROEnd_FailCiv1
	{
		title = "Mission Failed";
		subtitle = "Unacceptable Civilian Casualties";
		description = "Following the end of your mission and debriefing difficult questions were asked about the role your unit played. Though ultimately everyone related to the operation escaped punishment the civilian deaths made progress in the region harder and the conflict would continue.";
		pictureBackground = "images\recon_image_notext.jpg";
		picture = "";
		pictureColor[] = {0.5,0.4,0.4,1};
	};
	class DROEnd_FailCiv2
	{
		title = "Mission Failed";
		subtitle = "Unacceptable Civilian Casualties";		
		description = "The actions of your team on this day were widely condemned by the media and authorities. With the civilian deaths the enemy gained a powerful propaganda tool and the ranks of their army grew. Progress towards a peaceful solution became harder and the conflict was prolonged further than anyone expected. The families who lost loved ones would spend years struggling to be acknowledged.";
		pictureBackground = "images\recon_image_notext.jpg";
		picture = "";
		pictureColor[] = {0.5,0.4,0.4,1};
	};
};

/*
//SOG PF Radio Support config
class vn_artillery_settings
{
