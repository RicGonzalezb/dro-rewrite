// M3 — CfgFunctions migration (replaces #include lib pattern)
// All functions available as DRO_fnc_<name> before mission init
// ============================================================
class CfgFunctions
{
    class DRO
    {
        // -------------------------------------------------
        // Core lib functions (migrated from sundayFunctions,
        // droFunctions, menuFunctions, reviveFunctions,
        // generateEnemiesFunctions). Files in functions/fn_*.sqf
