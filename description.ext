        // -------------------------------------------------
        // AO generation (migrated from compile preprocessFile)
        // DRO_fnc_generateAO, DRO_fnc_generateAOLoc, etc.
        // -------------------------------------------------
        class generate_ao
        {
            class generateAO { file = "sunday_system\generate_ao\generateAO.sqf"; };
